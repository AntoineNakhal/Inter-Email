APP_ENV=local

API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=5173
FRONTEND_APP_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000

DATABASE_URL=sqlite:///./data/sqlite/app.db
CACHE_DIR=./data/cache
EXPORT_DIR=./data/exports

GMAIL_CREDENTIALS_PATH=./data/raw/google_credentials.json
GMAIL_TOKEN_DIR=./data/raw/gmail_tokens
GMAIL_MAX_RESULTS=50
GMAIL_THREAD_SOURCE=anywhere

AI_DEFAULT_PROVIDER=openai
AI_THREAD_ANALYSIS_PROVIDER=openai
AI_QUEUE_SUMMARY_PROVIDER=openai
AI_DRAFT_PROVIDER=openai
AI_CRM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL_THREAD_ANALYSIS=gpt-4.1-mini
OPENAI_MODEL_QUEUE_SUMMARY=gpt-4.1-mini
OPENAI_MODEL_DRAFT=gpt-4.1
OPENAI_MODEL_CRM=gpt-4.1-mini

ANTHROPIC_API_KEY=
# Haiku is strongly recommended for cost efficiency on all tasks.
# Use claude-sonnet-4-6 only for draft_reply if you need higher quality replies.
ANTHROPIC_MODEL_THREAD_ANALYSIS=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_QUEUE_SUMMARY=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_DRAFT=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_CRM=claude-haiku-4-5-20251001

# For direct local Ollama outside Docker:
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_THREAD_ANALYSIS=llama3.2:3b
OLLAMA_MODEL_QUEUE_SUMMARY=llama3.2:3b
OLLAMA_MODEL_DRAFT=llama3.2:3b
OLLAMA_MODEL_CRM=llama3.2:3b
